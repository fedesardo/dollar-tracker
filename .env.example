# Neon pooled connection (lo usa la app en runtime)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/finanzas?sslmode=require

# Neon direct connection (para drizzle-kit migrate)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/finanzas?sslmode=require

# Auth.js — generar con: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — Google Cloud Console → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Whitelist de emails autorizados (separados por coma)
ALLOWED_EMAILS=fedesardo@gmail.com,florenciaevans@gmail.com

# URL pública (sin slash final)
NEXT_PUBLIC_APP_URL=https://finanzas.fedesardo.com

# ──────────── DEV LOCAL ────────────
# Postgres local (docker-compose) corre en el puerto 5436 para no chocar con
# fedesardo.com (5432), liclarroza.com (5434) ni borgianas (5435).
# La app corre en localhost:3003 (3000=liclarroza, 3001=umami, 3002=borgianas).
#
# Para dev local, sobrescribí estas variables en .env.local:
#   DATABASE_URL=postgresql://finanzas:finanzas@localhost:5436/finanzas
#   DATABASE_URL_UNPOOLED=postgresql://finanzas:finanzas@localhost:5436/finanzas
#   NEXT_PUBLIC_APP_URL=http://localhost:3003
